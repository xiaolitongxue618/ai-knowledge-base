# AI 知识库系统 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# === Ollama 配置 ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
EMBEDDING_MODEL=nomic-embed-text

# === 应用配置 ===
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=3
MIN_SIMILARITY=0.3

# === 路径配置 ===
DATA_DIR=./data
VECTOR_STORE_DIR=./data/vector_store
METADATA_DB=./data/metadata/knowledge_base.db
LOG_FILE=./logs/app.log

# === 日志配置 ===
LOG_LEVEL=INFO
